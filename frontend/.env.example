# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit it.

# Your machine's local IP address + the Spring Boot port.
# Find your IP: run `ipconfig` (Windows) or `ifconfig` (Mac/Linux) and look for your Wi-Fi IPv4 address.
# Your phone and your laptop must be on the same Wi-Fi network.
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP:8080

# Azure Entra External ID — get these from the Azure Portal after app registration
# Portal: Entra ID → App Registrations
EXPO_PUBLIC_AZURE_TENANT_NAME=YOUR_TENANT_NAME
EXPO_PUBLIC_AZURE_FRONTEND_CLIENT_ID=YOUR_FRONTEND_APP_CLIENT_ID
EXPO_PUBLIC_AZURE_BACKEND_CLIENT_ID=YOUR_BACKEND_APP_CLIENT_ID
